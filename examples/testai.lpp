linkto "std"
linkto "mathlib"
linkto "ailib"

global test_pass_count: int = 0
global test_fail_count: int = 0
// let me clarify: THIS IS NOT AN LLM. IT's a small neural network
// That tests a XOR gate, because OR worked.
// You idiots (not the reader, im talking to someone else dw twin)
// REALLY THOUGHT that i'd code a damn gemini in, what? 70 lines?
// Retards.
func expect(label: str, ok: int): int {
    if ok {
        print_str("[PASS] " + label)
        test_pass_count += 1
    } else {
        print_str("[FAIL] " + label)
        test_fail_count += 1
    }
    return 0
}

func test_ai_nn_xor(): int {
    print_str("Testing Neural Network (XOR)")
    local nn: long = ai_nn_new(2, 4, 1, 0.5)
    local exp: long = ai_expected_new(1)

    for i = 0, 15000 {
        for j = 0, 4 {
            local b1: int = j & 1
            local b2: int = (j & 2) >> 1

            local x1: float = 0.0
            local x2: float = 0.0
            if b1 == 1 { x1 = 1.0 }
            if b2 == 1 { x2 = 1.0 }

            local target: float = 0.0
            if b1 != b2 { target = 1.0 }

            ai_nn_set_input(nn, 0, x1)
            ai_nn_set_input(nn, 1, x2)
            ai_nn_forward(nn)

            ai_expected_set(exp, 0, target)
            ai_nn_train(nn, exp)
        }
    }

    ai_nn_set_input(nn, 0, 1.0)
    ai_nn_set_input(nn, 1, 1.0)
    ai_nn_forward(nn)
    local out_11: float = ai_nn_get_output(nn, 0)

    ai_nn_set_input(nn, 0, 1.0)
    ai_nn_set_input(nn, 1, 0.0)
    ai_nn_forward(nn)
    local out_10: float = ai_nn_get_output(nn, 0)

    expect("XOR 1,1 is LOW", out_11 < 0.3)
    expect("XOR 1,0 is HIGH", out_10 > 0.7)

    ai_nn_free(nn)
    ai_expected_free(exp)
    return 0
}

func main(): int {
    test_ai_nn_xor()
    print_str("DONE!!!")
    print_str("Final Results:")
    print_int(test_pass_count)
    print_str("passed")
    return 0
}
