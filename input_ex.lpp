func factorial() : int {
    local n : int = 5
    local result : int = 1
    while n > 1 {
        result = result * n
        n = n - 1
    }
    print(result)
}

func main() : int {
    local a : int = 10
    local b : int = 5
    local sum : int = a + b
    local product : int = a * b
    
    print(sum)
    print(product)
    
    local i : int = 0
    while i < 5 {
        print(i)
        i = i + 1
    }
    
    factorial()
    return 0
}